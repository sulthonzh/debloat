{
  "name": "debloat",
  "version": "1.0.0",
  "description": "AI Dependency Bloat Detector & Fixer - Find and fix redundant, unnecessary, and hallucinated dependencies in AI-generated code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "debloat": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "dependencies",
    "npm",
    "bloat",
    "audit",
    "optimization",
    "cli",
    "typescript",
    "security"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "commander": "^11.1.0",
    "undici": "^5.26.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4"
  }
}