{
  "name": "debloat",
  "version": "1.1.0",
  "description": "AI Dependency Bloat Detector & Fixer - Find and fix redundant, unnecessary, and hallucinated dependencies in AI-generated code",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./analyzer.js": {
      "import": "./dist/analyzer.js"
    }
  },
  "bin": {
    "debloat": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --test test/*.test.js",
    "test:run": "node --test test/*.test.js",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "dependencies",
    "npm",
    "bloat",
    "audit",
    "optimization",
    "cli",
    "typescript",
    "security",
    "zero-dependency"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
"devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2"
  }
}
